{
  "name": "apt-novel-reviewer",
  "version": "0.1.0",
  "private": true,
  "description": "APT Local Novel Review Desktop App",
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "dev": "pnpm --filter @apt/desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  }
}
