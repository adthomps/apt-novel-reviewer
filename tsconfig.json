{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@apt/types": ["packages/types/src/index.ts"],
      "@apt/lib": ["packages/lib/src/index.ts"],
      "@apt/db": ["packages/db/src/index.ts"],
      "@apt/ui": ["packages/ui/src/index.ts"]
    }
  }
}
